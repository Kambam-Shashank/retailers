{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/d/[retailerId]/[designId].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/d/([^/]+)/([^/]+)",
      "dest": "/api/d/$1/$2"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}